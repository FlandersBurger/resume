,\"default_testimonials_title\":[{\"type\":\"heading1\",\"text\":\"What our customers say\",\"spans\":[]}],\"testimonials\":[{\"avatar\":{\"dimensions\":{\"width\":646,\"height\":650},\"alt\":\"Photo of Michael McKay, Principal Software Engineer\",\"copyright\":null,\"url\":\"https://images.prismic.io/launchdarkly-marketingsite/8f178a99-2f78-46b9-b916-54805c392c39_michael-mckay.jpeg?auto=compress,format\",\"id\":\"YM72yhMAACMAojd5\",\"edit\":{\"x\":0,\"y\":0,\"zoom\":1,\"background\":\"#fff\"}},\"testimonial\":[{\"type\":\"paragraph\",\"text\":\"We've been able to roll out new features at a pace that would've been unheard of a couple of years ago.\",\"spans\":[]}],\"name\":[{\"type\":\"heading6\",\"text\":\"Michael McKay\",\"spans\":[]}],\"company_name\":[{\"type\":\"paragraph\",\"text\":\"IBM\",\"spans\":[]}],\"job_title\":[{\"type\":\"heading6\",\"text\":\"Principal Software Engineer\",\"spans\":[]}]},{\"avatar\":{\"dimensions\":{\"width\":153,\"height\":154},\"alt\":\"Photo of Melanie Pickett, Northern Trust, Executive Vice President, Front Office Solutions\",\"copyright\":null,\"url\":\"https://images.prismic.io/launchdarkly-marketingsite/735bde47-b01b-4ad2-b2ac-e6bb8310715e_melanie-pickett.png?auto=compress,format\",\"id\":\"YTuY-BEAACIA1fVE\",\"edit\":{\"x\":0,\"y\":0,\"zoom\":1,\"background\":\"transparent\"}},\"testimonial\":[{\"type\":\"paragraph\",\"text\":\"My developers love LaunchDarkly. It’s a developer’s world; we all just live in it. And so if I can make my developers happy with great tools and productive, that’s a huge win.\",\"spans\":[]}],\"name\":[{\"type\":\"heading6\",\"text\":\"Melanie Pickett\",\"spans\":[]}],\"company_name\":[{\"type\":\"paragraph\",\"text\":\"Northern Trust\",\"spans\":[]}],\"job_title\":[{\"type\":\"heading6\",\"text\":\"Executive Vice President, Front Office Solutions\",\"spans\":[]}]},{\"avatar\":{\"dimensions\":{\"width\":102,\"height\":102},\"alt\":\"Photo of Manjari Ranganathan, Hawaiian Airlines, IT Manager\",\"copyright\":null,\"url\":\"https://images.prismic.io/launchdarkly-marketingsite/c5678df8-7d1f-46d8-95fa-d06f9c23f1bd_Ellipse+14+%282%29.png?auto=compress,format\",\"id\":\"YS15NREAACEAULOC\",\"edit\":{\"x\":0,\"y\":0,\"zoom\":1,\"background\":\"transparent\"}},\"testimonial\":[{\"type\":\"paragraph\",\"text\":\"We use LaunchDarkly to release new features to a subset of our guests, gather responses, fine-tune our approach, and validate new features in production to be able to deliver a better experience for all travelers.\",\"spans\":[]}],\"name\":[{\"type\":\"heading6\",\"text\":\"Manjari Ranganathan\",\"spans\":[]}],\"company_name\":[{\"type\":\"paragraph\",\"text\":\"Hawaiian Airlines\",\"spans\":[]}],\"job_title\":[{\"type\":\"heading6\",\"text\":\"IT Manager\",\"spans\":[]}]},{\"avatar\":{\"dimensions\":{\"width\":213,\"height\":213},\"alt\":\"Photo of Regis Wilson, SRE, TrueCar\",\"copyright\":null,\"url\":\"https://images.prismic.io/launchdarkly-marketingsite/976b2824-ee37-4e80-8bb5-c83abd25fc64_regis-wilson.png?auto=compress,format\",\"id\":\"YTuaDxEAACQA1foe\",\"edit\":{\"x\":0,\"y\":0,\"zoom\":1,\"background\":\"transparent\"}},\"testimonial\":[{\"type\":\"paragraph\",\"text\":\"TrueCar's AWS migration was the smoothest, most uneventful of any I've ever managed using LaunchDarkly.\",\"spans\":[]}],\"name\":[{\"type\":\"heading6\",\"text\":\"\u2028Regis Wilson\",\"spans\":[]}],\"company_name\":[{\"type\":\"paragraph\",\"text\":\"TrueCar\",\"spans\":[]}],\"job_title\":[{\"type\":\"heading6\",\"text\":\"Site Reliability Engineer\",\"spans\":[]}]},{\"avatar\":{\"dimensions\":{\"width\":177,\"height\":180},\"alt\":\"Photo of Rob Zuber, CircleCI, CTO\",\"copyright\":null,\"url\":\"https://images.prismic.io/launchdarkly-marketingsite/4fab0688-d834-4bb9-b6b9-e212d547df07_rob-zuber.png?auto=compress,format\",\"id\":\"YP7q4xIAACgA5zC8\",\"edit\":{\"x\":0,\"y\":0,\"zoom\":1,\"background\":\"transparent\"}},\"testimonial\":[{\"type\":\"paragraph\",\"text\":\"Feature flags are a critical piece of modern development, and\\nLaunchDarkly brings this part of continuous delivery to the masses.\",\"spans\":[]}],\"name\":[{\"type\":\"heading6\",\"text\":\"Rob Zuber\",\"spans\":[]}],\"company_name\":[{\"type\":\"paragraph\",\"text\":\"CircleCI\",\"spans\":[]}],\"job_title\":[{\"type\":\"heading6\",\"text\":\"CTO\",\"spans\":[]}]},{\"avatar\":{\"dimensions\":{\"width\":238,\"height\":239},\"alt\":\"daniel-archer-ritual-home-page\",\"copyright\":null,\"url\":\"https://images.prismic.io/launchdarkly-marketingsite/477a3eb0-b0a2-4e37-8ab7-0006cfbfd9bf_Daniel-Archer-Ritual-home-page.png?auto=compress,format\",\"id\":\"YpDn4REAACAAaoKL\",\"edit\":{\"x\":0,\"y\":0,\"zoom\":1,\"background\":\"transparent\"}},\"testimonial\":[{\"type\":\"paragraph\",\"text\":\"The main benefit of using LaunchDarkly experimentation is that it’s directly tied to the feature flag implementation. \",\"spans\":[]}],\"name\":[{\"type\":\"heading6\",\"text\":\"Daniel Archer\",\"spans\":[]}],\"company_name\":[{\"type\":\"paragraph\",\"text\":\"Ritual\",\"spans\":[]}],\"job_title\":[{\"type\":\"heading6\",\"text\":\"VP of Engineering\",\"spans\":[]}]}],\"client_logos\":[{\"client_name\":[{\"type\":\"heading3\",\"text\":\"SAP\",\"spans\":[]}],\"logo\":{\"link_type\":\"Media\",\"key\":\"f6b09aa9-a543-45ca-8b87-0d8255b42970\",\"kind\":\"image\",\"id\":\"YRsLuBAAACEAOEjb\",\"url\":\"https://images.prismic.io/launchdarkly-marketingsite/d601b7ca-49b3-4d6c-9392-832321b449a0_sap.svg?auto=compress,format\",\"name\":\"sap.svg\",\"size\":\"4318\",\"width\":\"36\",\"height\":\"19\"}},{\"client_name\":[{\"type\":\"heading3\",\"text\":\"NBC\",\"spans\":[]}],\"logo\":{\"link_type\":\"Media\",\"key\":\"0dded1da-a79c-478c-856a-c0920dd75db3\",\"kind\":\"image\",\"id\":\"YM_eIxMAACEApi8W\",\"url\":\"https://images.prismic.io/launchdarkly-marketingsite/eb7465e0-1f00-4031-a686-e48b7ee8259d_nbc.svg?auto=compress,format\",\"name\":\"nbc.svg\",\"size\":\"7099\",\"width\":\"153\",\"height\":\"40\"}},{\"