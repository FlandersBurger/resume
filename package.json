{
  "name": "resume",
  "scripts": {
    "rebuild": "rimraf dist && npm run bundle",
    "bundle": "tsc -p src/. && tsc-alias",
    "build": "tsc && tsc-alias",
    "watch": "concurrently --kill-others \"tsc -w -p src/.\" \"tsc-alias -w\" \"npm run dev\"",
    "dev": "tsx src/server.ts",
    "start": "npm run build -- -w",
    "translate": "cd src/scripts && node i18n-scanner.js",
    "client:dev": "vite",
    "client:build": "vite build",
    "client:preview": "vite preview",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepare": "husky"
  },
  "dependencies": {
    "asn1": "^0.2.6",
    "axios": "^1.16.1",
    "bcrypt-pbkdf": "^1.0.2",
    "bcryptjs": "^2.4.3",
    "bootstrap": "^4.5.2",
    "bson": "^4.1.0",
    "bull": "^4.12.2",
    "chalk": "^4.1.2",
    "chart.js": "^4.5.1",
    "discord.js": "^14.26.4",
    "dompurify": "^3.4.5",
    "dotenv": "^8.6.0",
    "express": "^4.19.2",
    "firebase": "^10.14.1",
    "firebase-admin": "^9.1.1",
    "firebaseui": "^6.1.0",
    "fuzzy-matching": "^0.4.3",
    "i18next": "^23.7.16",
    "i18next-fs-backend": "^2.3.1",
    "jwt-simple": "^0.5.6",
    "lodash": "^4.17.21",
    "module-alias": "^2.2.3",
    "moment": "^2.29.4",
    "mongoose": "^8.9.4",
    "mongoose-lean-virtuals": "^1.1.0",
    "morgan": "^1.10.0",
    "mtprotoproxy": "^2.0.0",
    "node-schedule": "^1.3.2",
    "nodemailer": "^6.9.11",
    "react": "^19.2.6",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.6",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.15.1",
    "redis": "^4.6.13",
    "rimraf": "^5.0.10",
    "styled-components": "^6.4.2",
    "tunnel-ssh": "^5.1.2",
    "ws": "^7.5.10",
    "xml2js": "^0.6.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css,md}": "prettier --write"
  },
  "devDependencies": {
    "@swc/core": "^1.4.12",
    "@swc/helpers": "^0.5.8",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcrypt": "^5.0.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/body-parser": "^1.19.5",
    "@types/dompurify": "^3.0.5",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jwt-simple": "^0.5.36",
    "@types/lodash": "^4.14.202",
    "@types/moment": "^2.13.0",
    "@types/mongoose-lean-virtuals": "^0.5.6",
