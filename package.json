    "husky": "^9.0.11",
    "i18n-auto-translation": "^1.8.1",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "lint-staged": "^15.2.5",
    "nodemon": "^3.1.0",
    "npm": "^10.8.2",
    "npm-check-updates": "^17.1.0",
    "prettier": "^3.3.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
